rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('role', 'buyer') == 'admin') ||
        (request.auth.token.email == 'mohamdggg732@gmail.com')
      );
    }

    function isMerchant() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getUserData().get('role', 'buyer') == 'merchant' || getUserData().get('role', 'buyer') == 'vip_merchant' || isAdmin());
    }

    match /public_users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      
      // Allow user to extensively update their own profile, catching specific administrative attempts
      allow update: if isOwner(userId) && (
        request.resource.data.get('role', 'buyer') != 'admin' ||
        request.resource.data.get('masterCode', '') == 'A7X-9KQ3-ZM81-PRO-MYSTORE-X99-ULTRA' ||
        isAdmin()
      ) || isAdmin();
      
      allow delete: if isAdmin();
    }

    match /codes/{codeId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated(); // Needed so users can increment usedCount when redeeming code
    }

    match /admin_codes/{codeId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isMerchant() || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); 
    }

    match /wallet_transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /recharge_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    match /ranks/{rankId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read, write: if isAuthenticated();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /gateways/{gatewayId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /shipping_methods/{methodId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isMerchant() || isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /withdrawal_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    match /buyer_merchant_trust/{trustId} {
      allow read, write: if isAuthenticated();
    }

    match /withdrawal_methods/{methodId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /admin_events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
