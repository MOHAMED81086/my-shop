rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().get('role', 'buyer') == 'admin' || 
        (request.auth.token.email == "mohamdggg732@gmail.com" && request.auth.token.get('email_verified', false) == true)
      );
    }
    
    function hasPermission(perm) {
      return isAdmin() || (isAuthenticated() && perm in getUserData().get('permissions', []));
    }
    
    function isMerchant() {
      let role = getUserData().get('role', 'buyer');
      return isAdmin() || (isAuthenticated() && (role == 'merchant' || role == 'vip_merchant'));
    }

    function isRecent(time) {
      return time > request.time - duration.value(5, 'm') && time < request.time + duration.value(5, 'm');
    }

    // ===============================================================
    // Public Users Collection (Non-PII lookup)
    // ===============================================================
    match /public_users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin() || (
        isAuthenticated() && 
        // Allow cross-user updates for wallet balance (for transfers) if needed, 
        // though transfers update the main 'users' collection.
        // Actually, only allow updates of balance by authenticated users if needed
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['wallet_balance'])
      );
    }

    // ===============================================================
    // Users Collection
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow user creation. Default role should be 'buyer'.
      allow create: if isOwner(userId) && (
        request.resource.data.role == 'buyer' ||
        isAdmin() ||
        (request.resource.data.role == 'admin' && request.resource.data.masterCode == 'A7X-9KQ3-ZM81-PRO-MYSTORE-X99-ULTRA')
      ) && 
      request.resource.data.name is string && request.resource.data.name.size() < 100 &&
      request.resource.data.username is string && request.resource.data.username.size() < 50 &&
      request.resource.data.password is string && request.resource.data.password.size() < 50 &&
      (!('wallet_balance' in request.resource.data) || request.resource.data.wallet_balance == 0) &&
      (!('points' in request.resource.data) || request.resource.data.points == 0) &&
      (!('blocked' in request.resource.data) || request.resource.data.blocked == false);
      
      // Allow updates.
      allow update: if (isOwner(userId) && (
        // Standard updates (no role/permission/blocked changes)
        (
          request.resource.data.get('role', resource.data.role) == resource.data.role &&
          (!('permissions' in request.resource.data) || request.resource.data.permissions == resource.data.get('permissions', [])) &&
          (!('blocked' in request.resource.data) || request.resource.data.blocked == resource.data.get('blocked', false)) &&
          (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() < 100)) &&
          (!('username' in request.resource.data) || (request.resource.data.username is string && request.resource.data.username.size() < 50)) &&
          (!('password' in request.resource.data) || (request.resource.data.password is string && request.resource.data.password.size() < 50))
        ) ||
        // VIP Upgrades
        (
          (request.resource.data.role == 'vip_buyer' && resource.data.get('wallet_balance', 0) - request.resource.data.wallet_balance >= 300) ||
          (request.resource.data.role == 'vip_merchant' && resource.data.get('wallet_balance', 0) - request.resource.data.wallet_balance >= 500)
        ) ||
        // Code Activation
        (
          'appliedCodeId' in request.resource.data &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'roleExpiryDate', 'originalRole', 'appliedCodeId', 'permissions', 'masterCode']) &&
          exists(/databases/$(database)/documents/codes/$(request.resource.data.appliedCodeId)) &&
          get(/databases/$(database)/documents/codes/$(request.resource.data.appliedCodeId)).data.get('isActive', false) == true &&
          get(/databases/$(database)/documents/codes/$(request.resource.data.appliedCodeId)).data.get('roleKey', '') == request.resource.data.role
        ) ||
        // Admin Access (Master Code or Admin Code)
        (
          request.resource.data.get('role', '') == 'admin' &&
          (
            request.resource.data.get('masterCode', '') == 'A7X-9KQ3-ZM81-PRO-MYSTORE-X99-ULTRA' ||
            exists(/databases/$(database)/documents/admin_codes/$(request.resource.data.get('masterCode', '')))
          )
        )
      )) || isAdmin() || (
        // Allow cross-user updates for wallet/merchant balance and points (for purchases/transfers)
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['wallet_balance', 'merchant_balance', 'points', 'referralCharged', 'referralCompleted']) &&
        (request.resource.data.get('wallet_balance', 0) is number) &&
        (request.resource.data.get('merchant_balance', 0) is number) &&
        (request.resource.data.get('points', 0) is number)
      );
    }

    // ===============================================================
    // Buyer-Merchant Trust Collection
    // ===============================================================
    match /buyer_merchant_trust/{trustId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.merchantId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuthenticated() && (request.resource.data.buyerId == request.auth.uid || resource.data.merchantId == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // Products Collection
    // ===============================================================
    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if (hasPermission('add_product') || isMerchant()) && 
        request.resource.data.title is string && request.resource.data.title.size() < 200 &&
        request.resource.data.price is number && request.resource.data.price >= 0;
      allow update: if hasPermission('edit_product') || (isMerchant() && resource.data.merchantId == request.auth.uid) || (
        isAuthenticated() && 
        // Allow buyers to update stock and delivery fields during purchase
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['stock', 'ratingAverage', 'codePool', 'accountList', 'fileUrl', 'downloadLink']) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'ratingAverage', 'codePool', 'accountList', 'fileUrl', 'downloadLink']) &&
        (request.resource.data.stock == null || resource.data.stock == null || (request.resource.data.stock <= resource.data.stock && request.resource.data.stock >= 0)) &&
        request.resource.data.price == resource.data.price &&
        request.resource.data.merchantId == resource.data.merchantId
      );
      allow delete: if hasPermission('delete_product') || (isMerchant() && resource.data.merchantId == request.auth.uid);
    }

    // ===============================================================
    // Orders Collection
    // ===============================================================
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasPermission('manage_orders'));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if hasPermission('manage_orders');
    }

    // ===============================================================
    // Wallet Transactions Collection
    // ===============================================================
    match /wallet_transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasPermission('manage_wallet') || hasPermission('manage_transfers'));
      // Only admins or specific permissions can create/update wallet transactions directly,
      // EXCEPT for transfers which we might handle via client-side transactions if rules allow, 
      // but it's safer to let the client write the transaction IF the balances are updated correctly.
      // To ensure atomic transfers from client, we'd need complex rules.
      // For this app, we will allow authenticated users to create a 'transfer' transaction 
      // ONLY IF they also update the balances correctly in a batch.
      // However, writing secure batch rules for transfers is very complex.
      // We will allow users to create pending transfers, or just allow creates if they match their uid.
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow update, delete: if hasPermission('manage_wallet') || hasPermission('manage_transfers');
    }

    // ===============================================================
    // Recharge Requests Collection
    // ===============================================================
    match /recharge_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasPermission('manage_recharge'));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if hasPermission('manage_recharge');
    }

    // ===============================================================
    // Ranks Collection
    // ===============================================================
    match /ranks/{rankId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('manage_ranks');
    }

    // ===============================================================
    // Tickets Collection
    // ===============================================================
    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // Reviews Collection
    // ===============================================================
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ===============================================================
    // Gateways Collection
    // ===============================================================
    match /gateways/{gatewayId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ===============================================================
    // Shipping Methods Collection
    // ===============================================================
    match /shipping_methods/{methodId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ===============================================================
    // Logs Collection
    // ===============================================================
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Logs are immutable
    }

    // ===============================================================
    // Notifications Collection
    // ===============================================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // Or admin
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ===============================================================
    // Settings Collection
    // ===============================================================
    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    // ===============================================================
    // Ads Collection
    // ===============================================================
    match /ads/{adId} {
      allow read: if true;
      allow create: if isMerchant();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['viewsLeft', 'status']) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsLeft', 'status'])
      ) || (isMerchant() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin() || (isMerchant() && resource.data.ownerId == request.auth.uid);
    }
    // ===============================================================
    // Roles Collection
    // ===============================================================
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    // ===============================================================
    // Codes Collection
    // ===============================================================
    match /codes/{codeId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount', 'isActive']) &&
        request.resource.data.usedCount == resource.data.usedCount + 1
      );
    }
    // ===============================================================
    // Withdrawal Requests Collection
    // ===============================================================
    match /withdrawal_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.merchantId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.merchantId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    // ===============================================================
    // Admin Codes Collection
    // ===============================================================
    match /admin_codes/{codeId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    // ===============================================================
    // Admin Events Collection
    // ===============================================================
    match /admin_events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===============================================================
    // Withdrawal Methods Collection
    // ===============================================================
    match /withdrawal_methods/{methodId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Credentials Collection (Auth Fallback)
    // ===============================================================
    match /credentials/{username} {
      // Anyone can try to get a credential doc to verify password
      allow get: if true;
      // Anyone can create if it doesn't exist
      allow create: if true;
      allow update, delete: if false;
    }

    // ===============================================================
    // Test Collection (for connection testing)
    // ===============================================================
    match /test/{docId} {
      allow read: if true;
    }
  }
}
